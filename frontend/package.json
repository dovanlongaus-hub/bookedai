{
  "name": "bookedai-frontend",
  "version": "1.0.5-tenant-panels",
  "private": true,
  "scripts": {
    "dev": "vite",
    "sync:template": "node scripts/sync-template-assets.mjs",
    "build": "node scripts/run-build.mjs",
    "build:widget": "vite build --config widget.config.ts",
    "build:chess": "vite build --config vite.chess.config.mts",
    "build:aimentor": "vite build --config vite.aimentor.config.mts",
    "preview": "vite preview --port 3000",
    "preview:chess": "vite preview --config vite.chess.config.mts --port 3001",
    "preview:aimentor": "vite preview --config vite.aimentor.config.mts --port 3002",
    "test:playwright": "bash scripts/run_playwright_suite.sh legacy",
    "test:playwright:admin": "bash scripts/run_playwright_suite.sh legacy --grep @admin",
    "test:playwright:admin-smoke": "bash scripts/run_admin_smoke.sh",
    "test:playwright:legacy": "bash scripts/run_legacy_smoke.sh",
    "test:playwright:live-read": "bash scripts/run_live_read_smoke.sh",
    "test:playwright:tenant-smoke": "bash scripts/run_tenant_smoke.sh",
    "test:playwright:examples": "bash scripts/run_playwright_suite.sh legacy tests/example-orchestration-flows.spec.ts",
    "test:playwright:basic-workflows": "bash scripts/run_basic_workflows.sh",
    "test:playwright:smoke": "npm run test:playwright:legacy && npm run test:playwright:live-read && npm run test:playwright:admin-smoke",
    "test:release-gate": "npm run build && PLAYWRIGHT_SKIP_BUILD=1 npm run test:playwright:smoke && PLAYWRIGHT_SKIP_BUILD=1 npm run test:playwright:tenant-smoke",
    "demo:chess": "PLAYWRIGHT_EXTERNAL_SERVER=1 npx playwright test tests/chess-booking-demo.spec.ts --headed --workers=1 --grep @chess-demo --project=legacy",
    "demo:chess:vi": "DEMO_LOCALE=vi PLAYWRIGHT_EXTERNAL_SERVER=1 npx playwright test tests/chess-booking-demo.spec.ts --headed --workers=1 --grep @chess-demo --project=legacy",
    "demo:chess:slow": "DEMO_LOCALE=en PLAYWRIGHT_EXTERNAL_SERVER=1 npx playwright test tests/chess-booking-demo.spec.ts --headed --workers=1 --grep @chess-demo --project=legacy --slow-mo=200"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.9.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.19.17",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
