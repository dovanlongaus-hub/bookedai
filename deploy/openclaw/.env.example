OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.12
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=UTC
OPENCLAW_CONFIG_DIR=/home/dovanlong/.openclaw-bookedai
OPENCLAW_WORKSPACE_DIR=/home/dovanlong/.openclaw-bookedai/workspace
BOOKEDAI_REPO_DIR=/home/dovanlong/BookedAI
CODEX_HOME_DIR=/home/dovanlong/.codex
OPENCLAW_GATEWAY_TOKEN=change-me
TELEGRAM_BOT_TOKEN=change-me
BOOKEDAI_TELEGRAM_TRUSTED_USER_IDS=8426853622
BOOKEDAI_TELEGRAM_ALLOWED_ACTIONS=sync_doc,sync_repo_docs,build_frontend,deploy_live,test,workspace_write,repo_structure,host_command,host_shell,full_project
OPENCLAW_INTERNAL_API_BRIDGE_PORT=18810
BOOKEDAI_INTERNAL_API_BASE_URL=http://backend:8000/api/internal/v1
BOOKEDAI_INTERNAL_TOKEN=bookedai-mvp-internal-dummy
# Public BookedAI API prefix (same paths as /api/... in the backend). Used by /public/booking-assistant/* browser proxy.
BOOKEDAI_PUBLIC_API_BASE_URL=http://backend:8000/api
OPENCLAW_BRIDGE_SHARED_TOKEN=change-me-openclaw-bridge
OPENCLAW_BRIDGE_REQUEST_TIMEOUT_SECONDS=25
OPENCLAW_BRIDGE_ALLOWED_PREFIXES=booking,search,communications,integrations
# Comma-separated browser origins allowed to call /public/... CORS (use * only without cookies; prefer explicit hosts)
OPENCLAW_BRIDGE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
OPENCLAW_BRIDGE_PUBLIC_STREAM_TIMEOUT_SECONDS=300
