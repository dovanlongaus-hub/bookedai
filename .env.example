# -----------------------------------------------------------------------------
# chess.bookedai.au student portal + payment options
# -----------------------------------------------------------------------------
# HMAC secret used to sign student session tokens issued by
# `/api/v1/students/google_auth`. Falls back to SESSION_SIGNING_SECRET when
# left empty so existing deploys keep working without an extra env var, but
# rotating in a dedicated value here is recommended for production.
STUDENT_AUTH_SECRET=change-me-student-jwt-secret
# Stripe success/cancel return URLs for the chess student-payment checkout.
CHESS_PAYMENT_SUCCESS_URL=https://chess.bookedai.au/account?payment=success
CHESS_PAYMENT_CANCEL_URL=https://chess.bookedai.au/?payment=cancelled

# -----------------------------------------------------------------------------
# Apple Wallet (.pkpass) — chess.bookedai.au order pass generation
# -----------------------------------------------------------------------------
# These four files + passphrase are required to sign a `.pkpass` archive.
# When any are blank or absent on disk, GET /api/v1/orders/{ref}/wallet/apple
# returns 503 with `apple_wallet_not_configured` so the frontend can hide the
# "Add to Apple Wallet" button gracefully.
#
# Setup:
#   1. developer.apple.com → Identifiers → Pass Type IDs → register one.
#   2. Generate a Pass certificate, export as .p12 (with passphrase).
#   3. Convert: openssl pkcs12 -in pass.p12 -out pass.pem -nodes
#                openssl pkcs12 -in pass.p12 -nocerts -out pass.key
#   4. Download Apple WWDR cert (G4) and convert to PEM.
#   5. Mount all three files at the paths configured here at deploy time.
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_PASS_CERT_PATH=
APPLE_WALLET_PASS_KEY_PATH=
APPLE_WALLET_PASS_KEY_PASSPHRASE=
APPLE_WALLET_WWDR_CERT_PATH=
APPLE_WALLET_ASSETS_DIR=backend/assets/wallet/chess

# -----------------------------------------------------------------------------
# Google Wallet — chess.bookedai.au order save URL
# -----------------------------------------------------------------------------
# Set EITHER GOOGLE_WALLET_SERVICE_ACCOUNT_JSON (raw inline JSON, base64-safe)
# OR GOOGLE_WALLET_SERVICE_ACCOUNT_JSON_PATH (filesystem path to the .json key).
# When unset, GET /api/v1/orders/{ref}/wallet/google returns 503 with
# `google_wallet_not_configured`.
#
# Setup:
#   1. console.cloud.google.com → enable "Google Wallet API".
#   2. Create a service account, grant it the "Wallet Object Issuer" role.
#   3. Download a JSON key for the service account.
#   4. wallet-api.google.com/walletobjects → create an Event Ticket Class.
#   5. Set GOOGLE_WALLET_ISSUER_ID + GOOGLE_WALLET_EVENT_CLASS_ID below.
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_EVENT_CLASS_ID=
