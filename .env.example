# -----------------------------------------------------------------------------
# App and public runtime
# -----------------------------------------------------------------------------
APP_NAME=BookedAI
PUBLIC_APP_URL=https://bookedai.au
PUBLIC_API_URL=https://api.bookedai.au
CORS_ALLOW_ORIGINS=https://bookedai.au,https://www.bookedai.au,https://admin.bookedai.au,https://product.bookedai.au,https://portal.bookedai.au,https://tenant.bookedai.au,https://futureswim.bookedai.au,https://chess.bookedai.au,https://aimentor.bookedai.au,https://ai.longcare.au,https://upload.bookedai.au,https://api.bookedai.au
VITE_API_BASE_URL=https://api.bookedai.au/api
VITE_GOOGLE_CLIENT_ID=
