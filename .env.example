# Telegram trusted operator allowlist - REPLACE the example user_id below with
# YOUR OWN Telegram user_id before deploying. Never commit a real id to source.
BOOKEDAI_TELEGRAM_TRUSTED_USER_IDS=8426853622
BOOKEDAI_TELEGRAM_ALLOWED_ACTIONS=sync_doc,sync_repo_docs,build_frontend,deploy_live,test,workspace_write,repo_structure,host_command,host_shell,openclaw_runtime_admin,whatsapp_bot_status,full_project
# Telegram operator host-shell - DEFAULTS OFF for safety (P1-S4, 2026-04-28).
# Set to 1 ONLY on a dedicated ops host with a tightly-scoped Telegram trusted
# operator allowlist. Leaving this OFF blocks the arbitrary-bash lane even if
# the bot token leaks or a Telegram chat is compromised.
BOOKEDAI_ENABLE_HOST_SHELL=0
# Customer-facing BookedAI Manager Bot for service search, booking, care, and retention.
# Telegram display name: BookedAI Manager Bot. Preferred username: @BookedAI_Manager_Bot.
# This is separate from OpenClaw/operator Telegram used for project programming/deploy actions.
BOOKEDAI_CUSTOMER_TELEGRAM_BOT_TOKEN=
BOOKEDAI_CUSTOMER_TELEGRAM_WEBHOOK_SECRET_TOKEN=
WHATSAPP_EVOLUTION_WEBHOOK_SECRET=
NOTION_API_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-too
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_DB_NAME=n8n
N8N_DB_USER=n8n_app
N8N_DB_PASSWORD=change-me-n8n

# -----------------------------------------------------------------------------
# Billing and payment
# -----------------------------------------------------------------------------
# These remain server-only and should be used by backend payment orchestration only.
# Use Stripe test keys (`sk_test_...`) for sandbox/dev. Do not put live secrets in
# local/shared files. Direct Stripe REST calls pin API version 2026-02-25.clover
# and rely on Dashboard Dynamic Payment Methods rather than hardcoded card-only
# checkout. Smoke test: `python3 scripts/stripe_sandbox_smoke.py --dry-run`.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=aud
# Required for /api/webhooks/stripe — get from Stripe Dashboard (Developers → Webhooks → endpoint signing secret).
# When unset, the webhook endpoint refuses every request with 401 to avoid silently accepting unsigned events.
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# CRM and calendar
# -----------------------------------------------------------------------------
ZOHO_CALENDAR_API_BASE_URL=https://calendar.zoho.com.au/api/v1
# Leave blank to auto-derive the correct Zoho Accounts domain from the CRM/Bookings API base URL.
# Examples: `https://accounts.zoho.com.au` for AU, `https://accounts.zoho.com` for US.
ZOHO_ACCOUNTS_BASE_URL=
ZOHO_CRM_API_BASE_URL=https://www.zohoapis.com.au/crm/v8
ZOHO_CRM_ACCESS_TOKEN=
ZOHO_CRM_REFRESH_TOKEN=
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=
ZOHO_CRM_DEFAULT_LEAD_MODULE=Leads
ZOHO_CRM_DEFAULT_CONTACT_MODULE=Contacts
ZOHO_CRM_DEFAULT_DEAL_MODULE=Deals
ZOHO_CRM_DEFAULT_TASK_MODULE=Tasks
ZOHO_CRM_NOTIFICATION_TOKEN=
ZOHO_CRM_NOTIFICATION_CHANNEL_ID=
ZOHO_CRM_NOTIFICATION_AUTO_RENEW_THRESHOLD_HOURS=24
ZOHO_CRM_NOTIFICATION_AUTO_RENEW_TIMEOUT_SECONDS=15
# Optional host-local route for cron maintenance to avoid Cloudflare in production.
ZOHO_CRM_NOTIFICATION_AUTO_RENEW_API_URL=
ZOHO_CRM_NOTIFICATION_AUTO_RENEW_HOST_HEADER=
ZOHO_CRM_NOTIFICATION_AUTO_RENEW_SKIP_TLS_VERIFY=false
ZOHO_CALENDAR_UID=
# For one combined Zoho OAuth consent, use the same client/refresh-token family
# as CRM, but the refresh token must include ZohoCalendar.event.CREATE,
# ZohoCalendar.calendar.READ, and ZohoMeeting.meeting.ALL.
ZOHO_CALENDAR_ACCESS_TOKEN=
ZOHO_CALENDAR_REFRESH_TOKEN=
ZOHO_CALENDAR_CLIENT_ID=
ZOHO_CALENDAR_CLIENT_SECRET=
ZOHO_BOOKINGS_API_BASE_URL=https://www.zohoapis.com.au/bookings/v1/json
ZOHO_BOOKINGS_ACCESS_TOKEN=
ZOHO_BOOKINGS_REFRESH_TOKEN=
ZOHO_BOOKINGS_CLIENT_ID=
ZOHO_BOOKINGS_CLIENT_SECRET=

