# -----------------------------------------------------------------------------
# App and public runtime
# -----------------------------------------------------------------------------
APP_NAME=BookedAI
PUBLIC_APP_URL=https://bookedai.au
PUBLIC_API_URL=https://api.bookedai.au
CORS_ALLOW_ORIGINS=https://bookedai.au,https://www.bookedai.au,https://admin.bookedai.au,https://product.bookedai.au,https://upload.bookedai.au
VITE_API_BASE_URL=https://api.bookedai.au/api
BACKEND_PORT=8001
GENERIC_TIMEZONE=Australia/Sydney
EXPOSE_API_DOCS=false

# -----------------------------------------------------------------------------
# Database and persistence
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://bookedai_app:change-me-app@supabase-db:5432/bookedai
APP_DB_NAME=bookedai
APP_DB_USER=bookedai_app
APP_DB_PASSWORD=change-me-app
SUPABASE_URL=https://supabase.bookedai.au
SUPABASE_ANON_KEY=replace-from-supabase-env
SUPABASE_SERVICE_ROLE_KEY=replace-from-supabase-env
SUPABASE_LOG_TABLE=conversation_events

# -----------------------------------------------------------------------------
# AI and search providers
# -----------------------------------------------------------------------------
# Primary model routing defaults. Keep server-only secrets out of frontend code.
AI_PROVIDER=qwen
AI_API_KEY=replace-me
AI_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
AI_MODEL=qwen-plus
AI_FALLBACK_PROVIDER=openai
AI_FALLBACK_API_KEY=replace-me
AI_FALLBACK_BASE_URL=https://api.openai.com/v1
AI_FALLBACK_MODEL=gpt-5-mini
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
SEMANTIC_SEARCH_ENABLED=false
SEMANTIC_SEARCH_PROVIDER=openai
SEMANTIC_SEARCH_API_KEY=
SEMANTIC_SEARCH_BASE_URL=https://api.openai.com/v1
SEMANTIC_SEARCH_MODEL=gpt-5-mini
SEMANTIC_SEARCH_TIMEOUT_SECONDS=12
SEMANTIC_SEARCH_MAX_CANDIDATES=8
SEMANTIC_SEARCH_GEMINI_MAPS_GROUNDING_ENABLED=false
GOOGLE_MAPS_STATIC_API_KEY=

# -----------------------------------------------------------------------------
# Booking, rate limiting, and upload runtime
# -----------------------------------------------------------------------------
BOOKING_CHAT_RATE_LIMIT_REQUESTS=20
BOOKING_CHAT_RATE_LIMIT_WINDOW_SECONDS=60
BOOKING_SESSION_RATE_LIMIT_REQUESTS=5
BOOKING_SESSION_RATE_LIMIT_WINDOW_SECONDS=300
BOOKING_BUSINESS_EMAIL=info@bookedai.au
UPLOAD_BASE_DIR=/app/storage/uploads
UPLOAD_PUBLIC_BASE_URL=https://upload.bookedai.au
UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# -----------------------------------------------------------------------------
# Automation and webhook runtime
# -----------------------------------------------------------------------------
TAWK_WEBHOOK_SECRET=replace-me
TAWK_VERIFY_SIGNATURE=false
N8N_HOST=n8n.bookedai.au
N8N_EDITOR_BASE_URL=https://n8n.bookedai.au
N8N_WEBHOOK_URL=https://n8n.bookedai.au/
N8N_BOOKING_WEBHOOK_URL=https://n8n.bookedai.au/webhook/bookedai-booking
N8N_API_KEY=replace-me
N8N_WEBHOOK_BEARER_TOKEN=replace-me
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_USERNAME=BookedAI Ops
DISCORD_WEBHOOK_AVATAR_URL=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-too
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_DB_NAME=n8n
N8N_DB_USER=n8n_app
N8N_DB_PASSWORD=change-me-n8n

# -----------------------------------------------------------------------------
# Billing and payment
# -----------------------------------------------------------------------------
# These remain server-only and should be used by backend payment orchestration only.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=aud

# -----------------------------------------------------------------------------
# CRM and calendar
# -----------------------------------------------------------------------------
ZOHO_CALENDAR_API_BASE_URL=https://calendar.zoho.com/api/v1
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_CALENDAR_UID=
ZOHO_CALENDAR_ACCESS_TOKEN=
ZOHO_CALENDAR_REFRESH_TOKEN=
ZOHO_CALENDAR_CLIENT_ID=
ZOHO_CALENDAR_CLIENT_SECRET=
ZOHO_BOOKINGS_API_BASE_URL=https://www.zohoapis.com.au/bookings/v1/json
ZOHO_BOOKINGS_ACCESS_TOKEN=
ZOHO_BOOKINGS_REFRESH_TOKEN=
ZOHO_BOOKINGS_CLIENT_ID=
ZOHO_BOOKINGS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email communications
# -----------------------------------------------------------------------------
# Current provider defaults point at Zoho Mail, but lifecycle logic should stay provider-agnostic.
EMAIL_SMTP_HOST=smtp.zoho.com.au
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=info@bookedai.au
EMAIL_SMTP_PASSWORD=replace-with-zoho-app-password
EMAIL_SMTP_FROM=info@bookedai.au
EMAIL_SMTP_USE_TLS=false
EMAIL_SMTP_USE_STARTTLS=true
EMAIL_IMAP_HOST=imap.zoho.com.au
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=info@bookedai.au
EMAIL_IMAP_PASSWORD=replace-with-zoho-app-password
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_IMAP_USE_SSL=true

# -----------------------------------------------------------------------------
# SMS and WhatsApp communications
# -----------------------------------------------------------------------------
SMS_PROVIDER=twilio
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_API_KEY_SID=
SMS_TWILIO_API_KEY_SECRET=
SMS_FROM_NUMBER=
SMS_MESSAGING_SERVICE_SID=
WHATSAPP_PROVIDER=twilio
WHATSAPP_TWILIO_ACCOUNT_SID=
WHATSAPP_TWILIO_AUTH_TOKEN=
WHATSAPP_TWILIO_API_KEY_SID=
WHATSAPP_TWILIO_API_KEY_SECRET=
WHATSAPP_FROM_NUMBER=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Admin runtime
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token
ADMIN_SESSION_TTL_HOURS=12

# -----------------------------------------------------------------------------
# Hermes service
# -----------------------------------------------------------------------------
HERMES_VERSION=v0.5.0
HERMES_BASE_URL=https://hermes.bookedai.au
HERMES_POSTGRES_HOST=supabase-db
HERMES_POSTGRES_PORT=5432
HERMES_POSTGRES_DB=hermes
HERMES_POSTGRES_USER=hermes_app
HERMES_POSTGRES_PASSWORD=replace-with-hermes-db-password
HERMES_ALGOLIA_APPLICATION_ID=
HERMES_ALGOLIA_SEARCH_API_KEY=
HERMES_ALGOLIA_WRITE_API_KEY=
HERMES_ALGOLIA_DOCS_INDEX_NAME=docs
HERMES_ALGOLIA_DRAFTS_INDEX_NAME=drafts
HERMES_ALGOLIA_INTERNAL_INDEX_NAME=internal
HERMES_ALGOLIA_LINKS_INDEX_NAME=links
HERMES_ALGOLIA_MISSING_FIELDS_INDEX_NAME=missing_fields
HERMES_ALGOLIA_PROJECTS_INDEX_NAME=projects
HERMES_GOOGLE_WORKSPACE_DOMAIN=
HERMES_GOOGLE_WORKSPACE_DOCS_FOLDER=
HERMES_GOOGLE_WORKSPACE_DRAFTS_FOLDER=
HERMES_GOOGLE_WORKSPACE_SHORTCUTS_FOLDER=
HERMES_GOOGLE_OAUTH2_CLIENT_ID=
HERMES_GOOGLE_OAUTH2_HD=
HERMES_GOOGLE_OAUTH2_REDIRECT_URI=https://hermes.bookedai.au/torii/redirect.html
HERMES_GOOGLE_AUTH_CLIENT_EMAIL=
HERMES_GOOGLE_AUTH_PRIVATE_KEY=
HERMES_GOOGLE_AUTH_SUBJECT=
HERMES_TEMPLATE_RFC=placeholder-rfc-template-id
HERMES_TEMPLATE_PRD=placeholder-prd-template-id

# -----------------------------------------------------------------------------
# Deployment and DNS automation
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id
CLOUDFLARE_AUTO_DNS_RECORDS=bookedai.au,www.bookedai.au,api.bookedai.au,admin.bookedai.au,n8n.bookedai.au,supabase.bookedai.au,hermes.bookedai.au,upload.bookedai.au,calendar.bookedai.au
CLOUDFLARE_AUTO_DNS_PROXIED_RECORDS=bookedai.au,www.bookedai.au,api.bookedai.au,admin.bookedai.au,n8n.bookedai.au,supabase.bookedai.au,hermes.bookedai.au,calendar.bookedai.au
